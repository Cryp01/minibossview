# =====================================================================
# mini-boss-view — production environment (Coolify)
# Copy each value into Coolify → your resource → Environment Variables.
# Mark the password/key as "Secret". Do NOT commit real values.
# =====================================================================

# --- PocketBase admin (dashboard at https://<your-domain>/_/) ---------
# First-boot superuser. Created automatically on the first deploy.
PB_SUPERUSER_EMAIL=admin@yourcompany.com
PB_SUPERUSER_PASSWORD=change-me-to-a-long-random-password

# --- Optional: encrypt PocketBase settings at rest --------------------
# 32-character key. Generate with:  openssl rand -hex 16
# Leave empty to disable encryption.
PB_ENCRYPTION_KEY=

# --- Domain (managed by Coolify) --------------------------------------
# Coolify fills SERVICE_FQDN_MINIBOSS_8090 when you assign a domain in the UI.
# You normally do NOT set this by hand.
# SERVICE_FQDN_MINIBOSS_8090=board.yourcompany.com
